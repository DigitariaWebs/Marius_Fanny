# MongoDB Connection
MONGODB_URI=your_mongodb_uri

# Server Configuration
PORT=3000

# Better Auth Configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-change-in-production-use-at-least-32-chars
FRONTEND_URL=http://localhost:5173

# Development/Production
NODE_ENV=development

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Cloudinary Configuration (for image uploads)
# Get these values from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Square Payment Configuration
# Get these values from https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_APPLICATION_ID=your_square_application_id_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_ENVIRONMENT=sandbox
# Note: Use 'sandbox' for testing, 'production' for live payments

# Twilio SMS Configuration
# Get these values from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000

# Safe local testing for SMS (no Twilio API call when true)
SMS_DRY_RUN=true

# Google Reviews (used in order emails)
# Best option: set the Laval Place ID so the link opens directly the review composer.
# Example: https://search.google.com/local/writereview?placeid=PLACE_ID
GOOGLE_REVIEW_PLACE_ID_LAVAL=
# Fallback: provide a full URL (overrides place id)
GOOGLE_REVIEW_URL=
